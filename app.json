{
  "expo": {
    "name": "mobile-foodstore-react-native",
    "slug": "mobile-foodstore-react-native",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "permissions": [
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#ffffff",
          "androidMode": "default"
        }
      ],
      "@react-native-google-signin/google-signin",
      "expo-local-authentication",
      [
        "expo-image-picker",
        {
          "photosPermission": "Izin untuk memilih foto dari galeri.",
          "cameraPermission": "Izin untuk mengambil foto profil."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "aac0b10f-ca4f-40ac-866d-cbe79a8fe82d"
      }
    },
    "owner": "anggawikanugraha"
  }
}
